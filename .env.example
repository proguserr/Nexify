DEBUG=1
SECRET_KEY=dev-secret-change-me
# Optional: extra hosts (comma-separated). localhost and 127.0.0.1 are always allowed.
# ALLOWED_HOSTS=api.example.com,example.com
DATABASE_URL=postgresql://app:app@localhost:5432/app

# --- Secrets: copy this file to `.env` and put real values there only ---
# `.env` is gitignored. Never commit API keys or paste them into `.env.example`.

# LLM triage: gemini | ollama | heuristic
LLM_PROVIDER=gemini
# Get a key from https://aistudio.google.com/ — paste ONLY in `.env`:
# GEMINI_API_KEY=your-key-here
# GEMINI_MODEL=gemini-2.0-flash

# Ollama (when LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3
